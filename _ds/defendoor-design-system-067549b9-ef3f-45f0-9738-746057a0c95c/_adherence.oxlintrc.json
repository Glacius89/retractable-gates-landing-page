{
  "plugins": [
    "react",
    "import"
  ],
  "rules": {
    "react/forbid-elements": [
      "warn",
      {
        "forbid": []
      }
    ],
    "no-restricted-imports": [
      "warn",
      {
        "patterns": [
          {
            "group": [
              "components/content/**",
              "components/forms/**",
              "components/marketing/**",
              "ui_kits/landing-page/**"
            ],
            "message": "Import design-system components from 'index.js', not component internals."
          }
        ]
      }
    ],
    "no-restricted-syntax": [
      "warn",
      {
        "selector": "Literal[value=/#[0-9a-fA-F]{3,8}\\b/]",
        "message": "Raw hex color — use a design-system color token via var()."
      },
      {
        "selector": "Literal[value=/\\b\\d+px\\b/]",
        "message": "Raw px value — use a design-system spacing token via var()."
      },
      {
        "selector": "Literal[value=/font-family\\s*:\\s*(?!['\\\"]?(?:Open Sans))/i]",
        "message": "Font not provided by the design system. Available: Open Sans."
      },
      {
        "selector": "JSXOpeningElement[name.name='AccordionItem'] > JSXAttribute > JSXIdentifier[name!=/^(?:q|a|key|ref|className|style|children)$/]",
        "message": "<AccordionItem> doesn't accept that prop. Declared props: q, a."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|tone|size|style|key|ref|className|style|children)$/]",
        "message": "<Badge> doesn't accept that prop. Declared props: children, tone, size, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='tone'] > Literal[value!=/^(?:accent|cta|teal|solid|dark)$/]",
        "message": "<Badge> tone must be one of 'accent' | 'cta' | 'teal' | 'solid' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Badge'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md)$/]",
        "message": "<Badge> size must be one of 'sm' | 'md'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute > JSXIdentifier[name!=/^(?:children|variant|size|block|href|type|disabled|icon|iconRight|onClick|style|key|ref|className|style|children)$/]",
        "message": "<Button> doesn't accept that prop. Declared props: children, variant, size, block, href, type, disabled, icon, iconRight, onClick, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='variant'] > Literal[value!=/^(?:primary|secondary|outline|ghost|dark)$/]",
        "message": "<Button> variant must be one of 'primary' | 'secondary' | 'outline' | 'ghost' | 'dark'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='size'] > Literal[value!=/^(?:sm|md|lg)$/]",
        "message": "<Button> size must be one of 'sm' | 'md' | 'lg'."
      },
      {
        "selector": "JSXOpeningElement[name.name='Button'] > JSXAttribute[name.name='type'] > Literal[value!=/^(?:button|submit|reset)$/]",
        "message": "<Button> type must be one of 'button' | 'submit' | 'reset'."
      },
      {
        "selector": "JSXOpeningElement[name.name='FeatureCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|title|description|tag|style|key|ref|className|style|children)$/]",
        "message": "<FeatureCard> doesn't accept that prop. Declared props: image, title, description, tag, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute > JSXIdentifier[name!=/^(?:label|id|as|type|placeholder|required|value|defaultValue|onChange|rows|hint|style|key|ref|className|style|children)$/]",
        "message": "<Input> doesn't accept that prop. Declared props: label, id, as, type, placeholder, required, value, defaultValue, onChange, rows, hint, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Input'] > JSXAttribute[name.name='as'] > Literal[value!=/^(?:input|textarea)$/]",
        "message": "<Input> as must be one of 'input' | 'textarea'."
      },
      {
        "selector": "JSXOpeningElement[name.name='LogoWallLogo'] > JSXAttribute > JSXIdentifier[name!=/^(?:src|name|key|ref|className|style|children)$/]",
        "message": "<LogoWallLogo> doesn't accept that prop. Declared props: src, name."
      },
      {
        "selector": "JSXOpeningElement[name.name='ModelCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:image|name|guarantee|specs|featured|ctaLabel|onCta|style|key|ref|className|style|children)$/]",
        "message": "<ModelCard> doesn't accept that prop. Declared props: image, name, guarantee, specs, featured, ctaLabel, onCta, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='Rating'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|max|size|showValue|count|style|key|ref|className|style|children)$/]",
        "message": "<Rating> doesn't accept that prop. Declared props: value, max, size, showValue, count, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='ReviewCard'] > JSXAttribute > JSXIdentifier[name!=/^(?:name|quote|rating|source|style|key|ref|className|style|children)$/]",
        "message": "<ReviewCard> doesn't accept that prop. Declared props: name, quote, rating, source, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute > JSXIdentifier[name!=/^(?:eyebrow|title|subtitle|align|onDark|style|key|ref|className|style|children)$/]",
        "message": "<SectionHeading> doesn't accept that prop. Declared props: eyebrow, title, subtitle, align, onDark, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='SectionHeading'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<SectionHeading> align must be one of 'left' | 'center'."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute > JSXIdentifier[name!=/^(?:value|label|onDark|align|style|key|ref|className|style|children)$/]",
        "message": "<StatBlock> doesn't accept that prop. Declared props: value, label, onDark, align, style."
      },
      {
        "selector": "JSXOpeningElement[name.name='StatBlock'] > JSXAttribute[name.name='align'] > Literal[value!=/^(?:left|center)$/]",
        "message": "<StatBlock> align must be one of 'left' | 'center'."
      }
    ]
  },
  "overrides": [
    {
      "files": [
        "**/index.js"
      ],
      "rules": {
        "no-restricted-imports": "off"
      }
    }
  ],
